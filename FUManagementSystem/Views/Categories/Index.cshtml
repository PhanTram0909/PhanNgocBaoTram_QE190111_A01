@using FUNewsManagementSystem.Model
@model IEnumerable<NewsCategory>
@{
    ViewData["Title"] = "Category Management";
    Layout = "_Layout";
    var allCategories = ViewBag.AllCategories as IEnumerable<NewsCategory> ?? new List<NewsCategory>();
}

@Html.AntiForgeryToken()

<div class="page-header">
    <div class="container-fluid px-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1><i class="bi bi-tags me-2"></i>Category Management</h1>
                <p class="subtitle">Manage news article categories</p>
            </div>
            <button class="btn btn-primary" onclick="openCreateModal()">
                <i class="bi bi-plus-lg me-2"></i>New Category
            </button>
        </div>
    </div>
</div>

<div class="container-fluid px-4">
    <!-- Search -->
    <div class="card mb-4">
        <div class="card-body py-3">
            <form method="get" asp-controller="Categories" asp-action="Index" class="d-flex gap-3">
                <div class="search-wrapper flex-grow-1">
                    <i class="bi bi-search"></i>
                    <input type="text" name="search" class="form-control" placeholder="Search categories..." value="@ViewBag.Search" />
                </div>
                <button type="submit" class="btn btn-primary">Search</button>
                @if (!string.IsNullOrWhiteSpace(ViewBag.Search as string))
                {
                    <a asp-controller="Categories" asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                }
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><i class="bi bi-list-ul me-2"></i>All Categories (@Model.Count())</div>
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>#ID</th>
                        <th>Category Name</th>
                        <th>Description</th>
                        <th>Parent</th>
                        <th>Status</th>
                        <th width="100">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var cat in Model)
                        {
                            <tr id="cat-row-@cat.CategoryId">
                                <td><span style="color:#64748b;font-family:monospace;">#@cat.CategoryId</span></td>
                                <td><strong>@cat.CategoryName</strong></td>
                                <td style="color:#94a3b8;font-size:0.875rem;">@(cat.CategoryDescription ?? "-")</td>
                                <td style="color:#94a3b8;font-size:0.875rem;">@(cat.ParentCategory?.CategoryName ?? "-")</td>
                                <td>
                                    @if (cat.IsActive) { <span class="badge badge-active">Active</span> }
                                    else { <span class="badge badge-inactive">Inactive</span> }
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-warning btn-icon btn-sm" title="Edit" onclick="openEditModal(@cat.CategoryId)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-danger btn-icon btn-sm" title="Delete" onclick="deleteCategory(@cat.CategoryId, '@cat.CategoryName')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6">
                            <div class="empty-state">
                                <i class="bi bi-tags icon"></i>
                                <h5>No categories found</h5>
                                <p>Create your first category.</p>
                            </div>
                        </td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- CREATE MODAL -->
<div class="modal fade" id="createCatModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-folder-plus me-2"></i>Create Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="createCatForm">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Category Name <span class="text-danger">*</span></label>
                        <input type="text" name="CategoryName" class="form-control" required maxlength="100" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="CategoryDescription" class="form-control" rows="2" maxlength="250"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Parent Category</label>
                        <select name="ParentCategoryId" class="form-select">
                            <option value="">None</option>
                            @foreach (var cat in allCategories)
                            {
                                <option value="@cat.CategoryId">@cat.CategoryName</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Status</label>
                        <select name="IsActive" class="form-select">
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check me-1"></i>Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- EDIT MODAL -->
<div class="modal fade" id="editCatModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>Edit Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editCatForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="CategoryId" id="editCatId" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Category Name <span class="text-danger">*</span></label>
                        <input type="text" name="CategoryName" id="editCatName" class="form-control" required maxlength="100" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="CategoryDescription" id="editCatDesc" class="form-control" rows="2" maxlength="250"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Parent Category</label>
                        <select name="ParentCategoryId" id="editCatParent" class="form-select">
                            <option value="">None</option>
                            @foreach (var cat in allCategories)
                            {
                                <option value="@cat.CategoryId">@cat.CategoryName</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Status</label>
                        <select name="IsActive" id="editCatActive" class="form-select">
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning"><i class="bi bi-check me-1"></i>Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- DELETE CONFIRM -->
<div class="modal fade delete-modal" id="confirmDeleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <i class="bi bi-trash warning-icon"></i>
                <p id="deleteConfirmMessage" class="text-secondary"></p>
            </div>
            <div class="modal-footer justify-content-center">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="confirmDeleteBtn" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let deleteCatId = null;

function openCreateModal() {
    document.getElementById('createCatForm').reset();
    bootstrap.Modal.getOrCreateInstance(document.getElementById('createCatModal')).show();
}

function openEditModal(id) {
    fetch(`/Categories/GetCategory?id=${id}`)
        .then(r => r.json())
        .then(cat => {
            if (!cat) { showToast('Category not found.', 'danger'); return; }
            document.getElementById('editCatId').value = cat.categoryId;
            document.getElementById('editCatName').value = cat.categoryName;
            document.getElementById('editCatDesc').value = cat.categoryDescription || '';
            document.getElementById('editCatParent').value = cat.parentCategoryId || '';
            document.getElementById('editCatActive').value = cat.isActive ? 'true' : 'false';
            bootstrap.Modal.getOrCreateInstance(document.getElementById('editCatModal')).show();
        });
}

function deleteCategory(id, name) {
    deleteCatId = id;
    document.getElementById('deleteConfirmMessage').textContent = `Delete category "${name}"?`;
    bootstrap.Modal.getOrCreateInstance(document.getElementById('confirmDeleteModal')).show();
}

document.getElementById('confirmDeleteBtn').addEventListener('click', function () {
    if (!deleteCatId) return;
    const token = document.querySelector('input[name="__RequestVerificationToken"]');
    const body = new URLSearchParams({ id: deleteCatId });
    if (token) body.append('__RequestVerificationToken', token.value);

    fetch('/Categories/Delete', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: body.toString() })
        .then(r => r.json())
        .then(data => {
            bootstrap.Modal.getInstance(document.getElementById('confirmDeleteModal')).hide();
            if (data.success) {
                document.getElementById(`cat-row-${deleteCatId}`)?.remove();
                showToast(data.message, 'success');
            } else showToast(data.message, 'danger');
            deleteCatId = null;
        });
});

document.getElementById('createCatForm').addEventListener('submit', function (e) {
    e.preventDefault();
    const token = document.querySelector('input[name="__RequestVerificationToken"]');
    fetch('/Categories/Create', { method: 'POST', headers: { 'RequestVerificationToken': token?.value ?? '' }, body: new FormData(this) })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                bootstrap.Modal.getInstance(document.getElementById('createCatModal')).hide();
                showToast(data.message, 'success');
                setTimeout(() => location.reload(), 1200);
            } else showToast(data.message, 'danger');
        });
});

document.getElementById('editCatForm').addEventListener('submit', function (e) {
    e.preventDefault();
    const token = document.querySelector('input[name="__RequestVerificationToken"]');
    fetch('/Categories/Edit', { method: 'POST', headers: { 'RequestVerificationToken': token?.value ?? '' }, body: new FormData(this) })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                bootstrap.Modal.getInstance(document.getElementById('editCatModal')).hide();
                showToast(data.message, 'success');
                setTimeout(() => location.reload(), 1200);
            } else showToast(data.message, 'danger');
        });
});
</script>
}
