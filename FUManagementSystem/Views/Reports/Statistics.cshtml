@{
    ViewData["Title"] = "Statistics Report";
    Layout = "_Layout";
}

<div class="page-header">
    <div class="container-fluid px-4">
        <h1><i class="bi bi-bar-chart me-2"></i>News Statistics Report</h1>
        <p class="subtitle">View articles published within a date range</p>
    </div>
</div>

<div class="container-fluid px-4">
    <!-- Filter -->
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-funnel me-2"></i>Filter by Date Range</div>
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Start Date</label>
                    <input type="date" id="startDate" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">End Date</label>
                    <input type="date" id="endDate" class="form-control" />
                </div>
                <div class="col-md-4">
                    <button class="btn btn-primary w-100" onclick="loadStats()">
                        <i class="bi bi-search me-2"></i>Generate Report
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row g-3 mb-4" id="summaryCards" style="display:none!important;">
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-number" id="totalCount">0</div>
                <div class="stat-label">Total Articles</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-number" id="activeCount" style="color:#10b981;">0</div>
                <div class="stat-label">Active Articles</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-number" id="inactiveCount" style="color:#ef4444;">0</div>
                <div class="stat-label">Inactive Articles</div>
            </div>
        </div>
    </div>

    <!-- Results Table -->
    <div class="card" id="resultsCard" style="display:none;">
        <div class="card-header" id="resultsHeader"><i class="bi bi-table me-2"></i>Report Results</div>
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Article ID</th>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Created By</th>
                        <th>Created Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody id="statsBody"></tbody>
            </table>
        </div>
    </div>

    <div id="emptyResult" style="display:none;">
        <div class="empty-state">
            <i class="bi bi-bar-chart icon"></i>
            <h5>No data found</h5>
            <p>No articles were found in the selected date range.</p>
        </div>
    </div>
</div>

@section Scripts {
<script>
// Set default date range (last 30 days)
const today = new Date();
const past = new Date(today); past.setDate(past.getDate() - 30);
document.getElementById('startDate').value = past.toISOString().split('T')[0];
document.getElementById('endDate').value = today.toISOString().split('T')[0];

function loadStats() {
    const start = document.getElementById('startDate').value;
    const end = document.getElementById('endDate').value;
    if (!start || !end) { showToast('Please select both start and end dates.', 'warning'); return; }
    if (new Date(start) > new Date(end)) { showToast('Start date cannot be after end date.', 'danger'); return; }

    fetch(`/Reports/GetStatistics?startDate=${start}&endDate=${end}`)
        .then(r => r.json())
        .then(data => {
            if (!data.success) { showToast(data.message, 'danger'); return; }

            const articles = data.data;
            const card = document.getElementById('resultsCard');
            const empty = document.getElementById('emptyResult');
            const summary = document.getElementById('summaryCards');

            if (articles.length === 0) {
                card.style.display = 'none';
                summary.style.display = 'none';
                empty.style.display = 'block';
                return;
            }

            // Summary
            const active = articles.filter(a => a.status === 'Active').length;
            document.getElementById('totalCount').textContent = articles.length;
            document.getElementById('activeCount').textContent = active;
            document.getElementById('inactiveCount').textContent = articles.length - active;
            summary.style.removeProperty('display');
            summary.style.display = 'flex';

            // Header
            document.getElementById('resultsHeader').innerHTML =
                `<i class="bi bi-table me-2"></i>Report: ${start} to ${end} — ${articles.length} article(s)`;

            // Table
            const body = document.getElementById('statsBody');
            body.innerHTML = articles.map(a => `
                <tr>
                    <td><span style="color:#64748b;font-family:monospace;font-size:0.8rem;">${a.newsArticleId}</span></td>
                    <td>
                        <div style="font-weight:500;">${a.newsTitle}</div>
                        <div style="color:#64748b;font-size:0.8rem;">${a.headline || ''}</div>
                    </td>
                    <td><span class="badge badge-role-staff">${a.categoryName}</span></td>
                    <td style="color:#94a3b8;font-size:0.875rem;">${a.createdBy}</td>
                    <td style="color:#94a3b8;font-size:0.875rem;">${a.createdDate ? new Date(a.createdDate).toLocaleDateString('en-GB') : ''}</td>
                    <td>${a.status === 'Active'
                        ? '<span class="badge badge-active">Active</span>'
                        : '<span class="badge badge-inactive">Inactive</span>'}</td>
                </tr>`).join('');

            card.style.display = 'block';
            empty.style.display = 'none';
        })
        .catch(() => showToast('Error loading statistics.', 'danger'));
}
</script>
}
