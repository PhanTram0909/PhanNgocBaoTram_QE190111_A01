@using FUNewsManagementSystem.Model
@model IEnumerable<SystemAccount>
@{
    ViewData["Title"] = "Account Management";
    Layout = "_Layout";
}

@Html.AntiForgeryToken()

<div class="page-header">
    <div class="container-fluid px-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1><i class="bi bi-people me-2"></i>Account Management</h1>
                <p class="subtitle">Manage system user accounts</p>
            </div>
            <button class="btn btn-primary" onclick="openCreateModal()">
                <i class="bi bi-person-plus me-2"></i>New Account
            </button>
        </div>
    </div>
</div>

<div class="container-fluid px-4">
    <div class="card mb-4">
        <div class="card-body py-3">
            <form method="get" asp-controller="Accounts" asp-action="Index" class="d-flex gap-3">
                <div class="search-wrapper flex-grow-1">
                    <i class="bi bi-search"></i>
                    <input type="text" name="search" class="form-control" placeholder="Search by name or email..." value="@ViewBag.Search" />
                </div>
                <button type="submit" class="btn btn-primary">Search</button>
                @if (!string.IsNullOrWhiteSpace(ViewBag.Search as string))
                {
                    <a asp-controller="Accounts" asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                }
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-list-ul me-2"></i>All Accounts (@Model.Count())</span>
        </div>
        <div class="table-responsive">
            <table class="table" id="accountsTable">
                <thead>
                    <tr>
                        <th>#ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th width="120">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var acc in Model)
                        {
                            <tr id="row-@acc.AccountId">
                                <td><span style="color:#64748b;font-family:monospace;">#@acc.AccountId</span></td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#6366f1,#0ea5e9);display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700;color:white;flex-shrink:0;">
                                            @acc.AccountName.Substring(0, 1).ToUpper()
                                        </div>
                                        <span>@acc.AccountName</span>
                                    </div>
                                </td>
                                <td style="color:#94a3b8;">@acc.AccountEmail</td>
                                <td>
                                    @switch (acc.AccountRole)
                                    {
                                        case 1:
                                            <span class="badge badge-role-staff">Staff</span>
                                            break;
                                        case 2:

                                            <span class="badge badge-role-lecturer">Lecturer</span>
                                            break;
                                        default:

                                            <span class="badge badge-role-admin">Admin</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-warning btn-icon btn-sm" title="Edit" onclick="openEditModal(@acc.AccountId)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-danger btn-icon btn-sm" title="Delete" onclick="deleteAccount(@acc.AccountId, '@acc.AccountName')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5">
                                <div class="empty-state">
                                    <i class="bi bi-people icon"></i>
                                    <h5>No accounts found</h5>
                                    <p>Create a new account to get started.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-person-plus me-2"></i>Create New Account</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="createForm">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Full Name <span class="text-danger">*</span></label>
                        <input type="text" name="AccountName" class="form-control" required maxlength="100" placeholder="Enter full name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email <span class="text-danger">*</span></label>
                        <input type="email" name="AccountEmail" class="form-control" required maxlength="150" placeholder="Enter email address" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Role <span class="text-danger">*</span></label>
                        <select name="AccountRole" class="form-select" required>
                            <option value="">Select role...</option>
                            <option value="1">Staff</option>
                            <option value="2">Lecturer</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password <span class="text-danger">*</span></label>
                        <input type="password" name="AccountPassword" class="form-control" required maxlength="200" placeholder="Enter password" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check me-1"></i>Create Account</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>Edit Account</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="AccountId" id="editAccountId" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Full Name <span class="text-danger">*</span></label>
                        <input type="text" name="AccountName" id="editAccountName" class="form-control" required maxlength="100" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email <span class="text-danger">*</span></label>
                        <input type="email" name="AccountEmail" id="editAccountEmail" class="form-control" required maxlength="150" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Role <span class="text-danger">*</span></label>
                        <select name="AccountRole" id="editAccountRole" class="form-select" required>
                            <option value="1">Staff</option>
                            <option value="2">Lecturer</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">New Password <small class="text-muted">(leave blank to keep current)</small></label>
                        <input type="password" name="AccountPassword" class="form-control" maxlength="200" placeholder="Leave blank to keep current password" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning"><i class="bi bi-check me-1"></i>Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade delete-modal" id="confirmDeleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <i class="bi bi-trash warning-icon"></i>
                <p id="deleteConfirmMessage" class="text-secondary">Are you sure you want to delete this account?</p>
            </div>
            <div class="modal-footer justify-content-center">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="confirmDeleteBtn" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let deleteAccountId = null;

        function openCreateModal() {
            document.getElementById('createForm').reset();
            bootstrap.Modal.getOrCreateInstance(document.getElementById('createModal')).show();
        }

        function openEditModal(id) {
            fetch(`/Accounts/GetAccount?id=${id}`)
                .then(r => r.json())
                .then(acc => {
                    if (!acc) { showToast('Account not found.', 'danger'); return; }
                    document.getElementById('editAccountId').value = acc.accountId;
                    document.getElementById('editAccountName').value = acc.accountName;
                    document.getElementById('editAccountEmail').value = acc.accountEmail;
                    document.getElementById('editAccountRole').value = acc.accountRole;
                    bootstrap.Modal.getOrCreateInstance(document.getElementById('editModal')).show();
                });
        }

        function deleteAccount(id, name) {
            deleteAccountId = id;
            document.getElementById('deleteConfirmMessage').textContent = `Delete account "${name}"? This action cannot be undone.`;
            bootstrap.Modal.getOrCreateInstance(document.getElementById('confirmDeleteModal')).show();
        }

        document.getElementById('confirmDeleteBtn').addEventListener('click', function () {
            if (!deleteAccountId) return;
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            const body = new URLSearchParams({ id: deleteAccountId });
            if (token) body.append('__RequestVerificationToken', token.value);

            fetch('/Accounts/Delete', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: body.toString() })
                .then(r => r.json())
                .then(data => {
                    bootstrap.Modal.getInstance(document.getElementById('confirmDeleteModal')).hide();
                    if (data.success) {
                        document.getElementById(`row-${deleteAccountId}`)?.remove();
                        showToast(data.message, 'success');
                    } else {
                        showToast(data.message, 'danger');
                    }
                    deleteAccountId = null;
                });
        });

        document.getElementById('createForm').addEventListener('submit', function (e) {
            e.preventDefault();
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            const formData = new FormData(this);
            fetch('/Accounts/Create', { method: 'POST', headers: { 'RequestVerificationToken': token?.value ?? '' }, body: formData })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        bootstrap.Modal.getInstance(document.getElementById('createModal')).hide();
                        showToast(data.message, 'success');
                        setTimeout(() => location.reload(), 1200);
                    } else {
                        showToast(data.message, 'danger');
                    }
                });
        });

        document.getElementById('editForm').addEventListener('submit', function (e) {
            e.preventDefault();
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            const formData = new FormData(this);
            fetch('/Accounts/Edit', { method: 'POST', headers: { 'RequestVerificationToken': token?.value ?? '' }, body: formData })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        bootstrap.Modal.getInstance(document.getElementById('editModal')).hide();
                        showToast(data.message, 'success');
                        setTimeout(() => location.reload(), 1200);
                    } else {
                        showToast(data.message, 'danger');
                    }
                });
        });
    </script>
}