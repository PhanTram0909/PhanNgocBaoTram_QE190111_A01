@using FUNewsManagementSystem.Model
@model NewsArticle
@{
    ViewData["Title"] = Model.NewsTitle;
    Layout = "_Layout";
}

<div class="container-fluid px-4 py-4" style="max-width:900px;margin:0 auto;">
    <div class="mb-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to News
        </a>
    </div>

    <div class="card p-4">
        <div class="mb-2">
            <span class="category-tag" style="background:rgba(99,102,241,0.15);color:#818cf8;display:inline-block;padding:0.3rem 0.75rem;border-radius:20px;font-size:0.8rem;font-weight:600;">
                <i class="bi bi-bookmark me-1"></i>@(Model.Category?.CategoryName ?? "General")
            </span>
        </div>
        <h1 style="font-size:1.8rem;font-weight:800;line-height:1.3;margin-bottom:0.75rem;">@Model.NewsTitle</h1>
        <p style="color:#94a3b8;font-size:1.05rem;font-style:italic;border-left:3px solid #6366f1;padding-left:1rem;margin-bottom:1.5rem;">@Model.Headline</p>

        <div class="d-flex align-items-center gap-3 mb-3" style="color:#64748b;font-size:0.875rem;">
            <span><i class="bi bi-person-circle me-1"></i>@(Model.CreatedBy?.AccountName ?? "Staff")</span>
            <span><i class="bi bi-calendar3 me-1"></i>@(Model.CreatedDate?.ToString("MMMM dd, yyyy") ?? "")</span>
            @if (Model.ModifiedDate.HasValue && Model.ModifiedDate != Model.CreatedDate)
            {
                <span><i class="bi bi-pencil me-1"></i>Updated @Model.ModifiedDate.Value.ToString("MMM dd, yyyy")</span>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.NewsSource))
        {
            <div class="mb-3 p-2" style="background:rgba(99,102,241,0.08);border-radius:8px;font-size:0.85rem;color:#94a3b8;">
                <i class="bi bi-link-45deg me-1"></i>Source: @Model.NewsSource
            </div>
        }

        <hr style="border-color:#334155;">

        <div style="line-height:1.8;color:#e2e8f0;font-size:0.95rem;">
            @(Model.NewsContent ?? "No content available.")
        </div>

        @if (Model.NewsTags != null && Model.NewsTags.Any())
        {
            <hr style="border-color:#334155;">
            <div>
                <span class="text-secondary me-2"><i class="bi bi-tags me-1"></i>Tags:</span>
                @foreach (var nt in Model.NewsTags)
                {
                    <span class="tag-pill"><i class="bi bi-hash"></i>@nt.Tag?.TagName</span>
                }
            </div>
        }
    </div>
</div>
